<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # 1. Manejar encabezados de Autorización (Importante para API/Seguridad)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # 2. Manejar Token XSRF (Seguridad de formularios de Laravel)
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # 3. REGLA DE ORO: Si el archivo existe físicamente, servirlo directamente
    # Esto es lo que permite que 'uploads/documentos/faj...png' se vea
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4. De lo contrario, enviar todas las solicitudes a index.php (Rutas de Laravel)
    RewriteRule ^ index.php [L]
</IfModule>
