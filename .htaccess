<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    
    # REGLA CRÍTICA: Si el archivo existe físicamente (ej. en la carpeta uploads), servirlo sin pasar por Laravel
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # De lo contrario, enviar todas las solicitudes a index.php para el enrutamiento de Laravel
    RewriteRule ^ index.php [L]
</IfModule>
